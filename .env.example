VITE_DJANGO_API_URL=http://127.0.0.1:8000/api

# Supabase (optional): enables cloud sync when set
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# When DJANGO_SECURITY_API_KEY is set on the server, set the same value here.
VITE_SECURITY_API_KEY=

# Optional: sent as tolerance on /api/face/verify/ (server default: FACE_RECOGNITION_TOLERANCE)
VITE_FACE_VERIFICATION_TOLERANCE=
