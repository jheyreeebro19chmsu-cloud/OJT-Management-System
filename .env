# Frontend (Vite) environment variables
# NOTE: Vite injects these at build-time. For hosted deployments, prefer setting these in your hosting platform's env settings.

# Django backend base URL (should include /api)
VITE_DJANGO_API_URL=http://localhost:8000/api

# Optional: if your Django backend enforces an API key, set the same value here
VITE_SECURITY_API_KEY=

# Optional client override for face verification tolerance
VITE_FACE_VERIFICATION_TOLERANCE=0.6

