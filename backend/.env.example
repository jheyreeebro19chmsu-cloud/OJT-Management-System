DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: require on all /api/* security routes except /api/health/
# Must match VITE_SECURITY_API_KEY in the frontend .env when set.
DJANGO_SECURITY_API_KEY=

# Comma-separated origins (locks CORS). Include common Vite ports.
DJANGO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Face compare threshold (lower = stricter). Tune with real lighting/devices.
FACE_RECOGNITION_TOLERANCE=0.6

# Behind HTTPS reverse proxy: set to 1
# DJANGO_USE_HTTPS=1
